#!/usr/bin/env lua

package.cpath = package.cpath .. ";/Users/deevs/.local/share/sketchybar_lua/?.so"

for module_name, _ in pairs(package.loaded) do
    if module_name == "helpers"
        or module_name == "bar"
        or module_name == "default"
        or module_name == "items"
        or module_name == "colors"
        or module_name == "icons"
        or module_name == "settings"
        or module_name:match("^helpers%.")
        or module_name:match("^items%.")
    then
        package.loaded[module_name] = nil
    end
end

-- Require the sketchybar module first
sbar = require("sketchybar")

-- Load helpers and prepare the helper binaries
require("helpers")

-- Bundle the entire initial configuration into a single message to sketchybar
sbar.begin_config()
require("bar")
require("default")
require("items")
sbar.end_config()

-- Run the event loop of the sketchybar module
sbar.event_loop()
