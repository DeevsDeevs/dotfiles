{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "theme": "catppuccin",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": {{ output "sh" "-c" "if command -v op >/dev/null 2>&1; then op read --no-newline 'op://JustEnvs/context7-api-key/credential' 2>/dev/null || true; fi" | toJson }}
      },
      "enabled": true
    }
  }
}
