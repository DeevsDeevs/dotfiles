{{- /* chezmoi:modify-template */ -}}
{{- $apiKey := output "sh" "-c" "if command -v op >/dev/null 2>&1; then op read --no-newline 'op://JustEnvs/context7-api-key/credential' </dev/null 2>/dev/null || true; fi" -}}
{{- $config := dict -}}
{{- if ne (trim .chezmoi.stdin) "" -}}
{{-   $config = fromJson .chezmoi.stdin -}}
{{- end -}}
{{- if not (hasKey $config "mcpServers") -}}
{{-   $_ := set $config "mcpServers" dict -}}
{{- end -}}
{{- $context7 := dict
  "type" "http"
  "url" "https://mcp.context7.com/mcp"
  "headers" (dict "CONTEXT7_API_KEY" $apiKey)
-}}
{{- $datadog := dict
  "type" "http"
  "url" "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp"
-}}
{{- $_ := set $config.mcpServers "context7" $context7 -}}
{{- $_ := set $config.mcpServers "datadog" $datadog -}}
{{- $config | toPrettyJson -}}
