export DEVBOX_NO_PROMPT=true
eval "$(devbox global shellenv --init-hook)"

{{ if eq .chezmoi.os "darwin" -}}
export EDITOR="zeditor --wait"
{{ else -}}
export EDITOR="nvim"
export COLORTERM=truecolor
{{ end -}}

export LS_COLORS="$(vivid generate catppuccin-mocha)"

ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

zinit snippet OMZL::git.zsh
zinit snippet OMZP::git
zinit snippet OMZP::sudo
zinit snippet OMZP::docker
zinit snippet OMZP::docker-compose
zinit snippet OMZP::command-not-found

autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qNmh+24) ]]; then
  compinit
else
  compinit -C
fi

zinit cdreplay -q

eval "$(starship init zsh)"

bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region

HISTSIZE=5000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'ls --color $realpath'

mkdir ~/.cache/zinit/completions > /dev/null 2>&1

alias ls='ls --color'
alias vim='nvim'
alias c='clear'

dbsync() {
  chezmoi add ~/.local/share/devbox/global/default/devbox.json
  echo "✓ Synced devbox.json to chezmoi"
}

_is_devbox_flake_ref() {
  case "$1" in
    github:*|gitlab:*|sourcehut:*|git+*|path:*) return 0 ;;
    *) return 1 ;;
  esac
}

_devbox_raise_nofile_limit() {
  local current hard target=8192

  current="$(ulimit -n 2>/dev/null)" || return 0
  [[ "$current" == "unlimited" ]] && return 0
  [[ -z "$current" || "$current" -ge "$target" ]] && return 0

  hard="$(ulimit -H -n 2>/dev/null)" || hard=""
  if [[ -n "$hard" && "$hard" != "unlimited" && "$hard" -lt "$target" ]]; then
    target="$hard"
  fi

  ulimit -n "$target" 2>/dev/null || true
}

_dbupdate_flake_ref() {
  local pkg="$1"
  local flake_ref="${pkg%%#*}"
  local devbox_json backup

  _devbox_raise_nofile_limit

  echo "↻ Refreshing flake metadata for ${flake_ref}"
  nix flake metadata "$flake_ref" --refresh > /dev/null || return

  devbox_json="$(devbox global path)/devbox.json" || return
  backup="$(mktemp)" || return
  cp "$devbox_json" "$backup" || { rm -f "$backup"; return 1; }

  echo "↻ Re-adding flake package ${pkg}"
  if ! devbox global rm "$pkg"; then
    echo "! Remove failed; restoring ${devbox_json}"
    cp "$backup" "$devbox_json"
    rm -f "$backup"
    return 1
  fi

  if ! devbox global add "$pkg"; then
    echo "! Re-add failed; restoring ${devbox_json}"
    cp "$backup" "$devbox_json"
    rm -f "$backup"
    return 1
  fi

  rm -f "$backup"
}

dbadd() {
  _devbox_raise_nofile_limit
  devbox global add "$@" && dbsync
}

dbrm() {
  _devbox_raise_nofile_limit
  devbox global rm "$@" && dbsync
}

dbupdate() {
  _devbox_raise_nofile_limit

  if [[ $# -eq 0 ]]; then
    devbox global update && dbsync
    return
  fi

  local pkg
  local -a registry_pkgs flake_pkgs
  for pkg in "$@"; do
    if _is_devbox_flake_ref "$pkg"; then
      flake_pkgs+=("$pkg")
    else
      registry_pkgs+=("$pkg")
    fi
  done

  if [[ ${#registry_pkgs[@]} -gt 0 ]]; then
    devbox global update "${registry_pkgs[@]}" || return
  fi

  for pkg in "${flake_pkgs[@]}"; do
    _dbupdate_flake_ref "$pkg" || return
  done

  dbsync
}

dbup() {
  dbupdate "$@"
}

dbadd-mac() {
  devbox global add "$@" --platform x86_64-darwin,aarch64-darwin && dbsync
}

dbadd-linux() {
  devbox global add "$@" --platform x86_64-linux,aarch64-linux && dbsync
}

if command -v fzf > /dev/null; then
  FZF_VERSION=$(fzf --version | awk '{print $1}')
  if [[ "$(printf '%s\n' 0.48.0 "$FZF_VERSION" | sort -V | head -n1)" == "0.48.0" ]]; then
    eval "$(fzf --zsh)"
  fi
fi

if [ -z "$DISABLE_ZOXIDE" ] && [[ $- == *i* ]]; then
    eval "$(zoxide init --cmd cd zsh)"
fi

if command -v wagner > /dev/null; then
  eval "$(wagner completions zsh)"
fi

if command -v codex > /dev/null; then
  eval "$(codex completion zsh)"
fi

export PATH="$HOME/.local/bin:$HOME/.npm-global/bin:$PATH"
